<?xml version='1.0' encoding='UTF-8'?>
<model name="TwoMinima" xmlns="http://www.cellml.org/cellml/1.1#" xmlns:cellml="http://www.cellml.org/cellml/1.1#">
    <component name="TwoMinima_main_type">
        <variable name="t" public_interface="in" units="second"/>
        <variable name="x_init" public_interface="in" units="dimensionless"/>
        <variable name="a" public_interface="in" units="dimensionless"/>
        <variable name="c" public_interface="in" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>x</ci>
                </apply>
                <apply>
                    <times/>
                    <ci>c</ci>
                    <apply>
                        <minus/>
                        <apply>
                            <times/>
                            <ci>a</ci>
                            <ci>a</ci>
                        </apply>
                        <ci>x</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="x_init" name="x" public_interface="out" units="dimensionless"/>
    </component>
</model>
